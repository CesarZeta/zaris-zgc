{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "regions": ["gru1"],
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": { "includeFiles": ["backend/app/**"] }
    }
  ],
  "routes": [{ "src": "/(.*)", "dest": "api/index.py" }],
  "crons": [{ "path": "/health/db", "schedule": "0 9 * * *" }]
}
